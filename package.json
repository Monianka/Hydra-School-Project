{
  "name": "hydra-school-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w web",
    "build:web": "npm run build -w web",
    "start:web": "npm run start -w web",
    "dev:backend": "npm run dev -w packages/backend",
    "start:backend": "npm start -w packages/backend",
    "lint": "npm run lint -w web || true"
  }
}
